{
  "name": "sns-marketing-nuxt",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt prepare && prisma generate && nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && prisma generate",
    "start": "pm2 start ecosystem.config.cjs",
    "stop": "pm2 stop sns-factory",
    "restart": "pm2 restart sns-factory --update-env",
    "logs": "pm2 logs sns-factory",
    "status": "pm2 status",
    "seo:smoke": "node scripts/seo-smoke.mjs",
    "deploy": "npm run build && pm2 restart sns-factory --update-env"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "@sidebase/nuxt-auth": "^1.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "next-auth": "^4.21.1",
    "nuxt": "^4.4.6",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxtjs/seo": "^5.1.3",
    "@types/bcryptjs": "^2.4.6",
    "opentype.js": "^2.0.0",
    "tsx": "^4.22.2"
  },
  "//optionalDependencies": "CF(리눅스) 빌드용 네이티브 바이너리를 직접 의존성으로 고정. 간접 optional 로만 두면 npm ci 가 리눅스에서 설치를 건너뛰는 버그(npm #4828)로 'Cannot find @oxc-parser/binding-linux-x64-gnu' 발생. Windows 로컬에선 os 불일치라 자동 skip 됨. oxc/rollup/esbuild 버전과 반드시 일치시킬 것.",
  "optionalDependencies": {
    "@oxc-parser/binding-linux-x64-gnu": "0.131.0",
    "@rollup/rollup-linux-x64-gnu": "4.60.4",
    "@esbuild/linux-x64": "0.28.0"
  }
}
