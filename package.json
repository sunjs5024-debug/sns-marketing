{
  "name": "sns-marketing-nuxt",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt prepare && prisma generate && nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && prisma generate",
    "start": "pm2 start ecosystem.config.cjs",
    "stop": "pm2 stop sns-factory",
    "restart": "pm2 restart sns-factory --update-env",
    "logs": "pm2 logs sns-factory",
    "status": "pm2 status",
    "seo:smoke": "node scripts/seo-smoke.mjs",
    "deploy": "npm run build && pm2 restart sns-factory --update-env"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "@sidebase/nuxt-auth": "^1.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "next-auth": "^4.21.1",
    "nuxt": "^4.4.6",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxtjs/seo": "^5.1.3",
    "@types/bcryptjs": "^2.4.6",
    "opentype.js": "^2.0.0",
    "tsx": "^4.22.2"
  }
}
