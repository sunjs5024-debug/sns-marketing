# .env.example - 이 파일을 .env 로 복사하고 값을 채우세요

# 필수 - Neon Postgres 연결 문자열 (https://console.neon.tech)
DATABASE_URL="postgresql://user:pass@host.neon.tech/neondb?sslmode=require"

# 필수 - JWT 세션 암호화 (32바이트 hex 권장)
# 새로 생성: openssl rand -hex 32  또는 PowerShell: -join ((1..32) | %{ '{0:x2}' -f (Get-Random -Maximum 256) })
NUXT_AUTH_SECRET=""

# 배포 URL (로컬은 http://localhost:3001)
NEXTAUTH_URL="http://localhost:3001"

# 카카오 로그인 (선택) - https://developers.kakao.com
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# 네이버 로그인 (선택) - https://developers.naver.com/apps
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# 구글 로그인 (선택) - https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# 포트원(PortOne) v2 결제 (선택) - 비어있으면 mock 결제 모드
PORTONE_STORE_ID=""
PORTONE_API_SECRET=""
NUXT_PUBLIC_PORTONE_CHANNEL_KEY=""
